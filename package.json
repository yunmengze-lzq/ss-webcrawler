{
  "name": "xiaoleng-toolbox",
  "version": "1.0.0",
  "description": "小冷工具箱 - 本地接口取数与数据整理工具",
  "main": "dist-electron/index.js",
  "engines": {
    "node": "24.14.1",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite --config vite.config.mjs",
    "build": "node scripts/build-offline.mjs",
    "test": "node --test --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON tests/*.test.mjs",
    "experiment:github": "node --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/run-real-site-experiment.mjs",
    "typecheck": "vue-tsc --noEmit",
    "preview": "vite preview --config vite.config.mjs",
    "build:vite": "vite build --config vite.config.mjs",
    "build:app": "set TS_AGENT_BUILD_APP=1&& node scripts/build-offline.mjs"
  },
  "dependencies": {
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "pinia": "^2.1.7",
    "element-plus": "^2.6.1",
    "echarts": "^5.5.0",
    "dayjs": "^1.11.10",
    "electron-log": "^5.1.2",
    "node-schedule": "^2.1.1",
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitejs/plugin-vue": "^5.0.3",
    "electron": "^29.1.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vite-plugin-electron": "^0.28.4",
    "vue-tsc": "^1.8.27"
  },
  "build": {
    "appId": "com.xiaoleng.toolbox",
    "productName": "小冷工具箱",
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}_v${version}.${ext}"
    },
    "extraResources": [
      {
        "from": "./python",
        "to": "./python"
      },
      {
        "from": "./storage",
        "to": "./storage"
      }
    ]
  }
}
